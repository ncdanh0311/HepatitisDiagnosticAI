# .env.example — copy to .env and fill in secrets

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=hepatitis_db
DATABASE_URL=postgresql+asyncpg://postgres:change_me_in_production@postgres:5432/hepatitis_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Auth ──────────────────────────────────────────────────────────────────────
SECRET_KEY=REPLACE_WITH_openssl_rand_-hex_32_output
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Internal Services ─────────────────────────────────────────────────────────
ML_SERVICE_URL=http://ml-service:8001
RAG_SERVICE_URL=http://rag-service:8002
MLFLOW_TRACKING_URI=http://mlflow:5000
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=hepatitis_docs

# ── AI / LLM ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── ML Model ─────────────────────────────────────────────────────────────────
MODEL_PATH=models/trainer_binary.pkl

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost/api/v1
